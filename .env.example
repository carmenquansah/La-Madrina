# MongoDB Atlas connection string (replica set required for Prisma writes)
DATABASE_URL="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/la_madrina?retryWrites=true&w=majority"

# Secret for signing session cookies — generate with: node -e "require('crypto').randomBytes(48).toString('hex') |> console.log"
SESSION_SECRET="generate-a-64-char-random-hex-string"

# Public URL — used in owner notification emails (no trailing slash)
APP_URL="https://your-domain.vercel.app"

# Payment details shown to customers at checkout
PAYMENT_MOMO_NETWORK="MTN"
PAYMENT_MOMO_NUMBER="0546368357"
PAYMENT_MOMO_NAME="La Madrina Bakery"
PAYMENT_WHATSAPP="0546368357"

# Gmail SMTP for order notifications
# Get GMAIL_APP_PASSWORD from: myaccount.google.com/apppasswords (requires 2FA)
GMAIL_USER="you@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
NOTIFY_EMAIL="you@gmail.com"
