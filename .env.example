# MongoDB. Prisma writes (creates/updates) need a replica set — MongoDB Atlas works out of the box.
# Local standalone MongoDB: use a single-node replica set or prismagraphql/mongo-single-replica (see Prisma MongoDB docs).
DATABASE_URL="mongodb://localhost:27017/la_madrina"

# Secret for signing session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET="your-session-secret-at-least-32-chars"
